# Frontend URL used by the browser to call FastAPI.
# For local Docker Compose, keep this as localhost because the browser runs on your host.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional future map token. Leave blank if this PoC does not use Mapbox yet.
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# Optional data/API key placeholders for future live source integrations.
DATA_API_KEY=
SEC_USER_AGENT=Crowdfunding Deal Radar PoC

# Host ports exposed by Docker Compose.
FRONTEND_PORT=3000
BACKEND_PORT=8000
