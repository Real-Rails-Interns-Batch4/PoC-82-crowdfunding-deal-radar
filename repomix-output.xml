  value: string;
  values: string[];
  onChange: (value: string) => void;
}) {
  return (
    <label className="flex h-9 items-center gap-2 rounded-md border border-border bg-[#0E111B]/80 px-3 text-sm text-slate-300 shadow-[0_0_18px_rgba(45,212,191,0.08)] backdrop-blur">
